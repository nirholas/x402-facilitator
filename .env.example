# three.ws x402 Facilitator — Environment Variables

# Required: private key for the settlement wallet (funds gas on each chain)
FACILITATOR_PRIVATE_KEY=0x...

# RPC endpoints (public defaults used if not set)
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ETHEREUM_RPC_URL=https://eth.llamarpc.com

# Chain enable flags (all enabled by default)
ENABLE_BASE=true
ENABLE_BASE_SEPOLIA=false
ENABLE_ARBITRUM=true
ENABLE_ARBITRUM_SEPOLIA=false
ENABLE_ETHEREUM=true

# Server
PORT=3402
HOST=0.0.0.0

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# CORS (comma-separated origins, * for all)
CORS_ORIGINS=*

# Logging
LOG_LEVEL=info
