{
  "name": "@threews/x402-facilitator",
  "version": "2.0.0",
  "description": "three.ws x402 facilitator — verify and settle USDC micropayments on EVM chains",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.7.6",
    "hono": "^4.6.0",
    "lru-cache": "^11.2.7",
    "viem": "^2.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nirholas/x402-facilitator"
  },
  "keywords": ["x402", "facilitator", "micropayments", "USDC", "EIP-3009", "Base", "Arbitrum"]
}
